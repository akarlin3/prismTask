# Gradle
.gradle/
build/
local.properties

# Track debug APK even though build/ is ignored
!app/build/
app/build/*
!app/build/outputs/
app/build/outputs/*
!app/build/outputs/apk/
app/build/outputs/apk/*
!app/build/outputs/apk/debug/
app/build/outputs/apk/debug/*
!app/build/outputs/apk/debug/app-debug.apk

# Kotlin
.kotlin/
.kotlin/errors/

# IDE
.idea/
!.idea/codeStyles/
*.iml
.vscode/

# Android
*.ap_
captures/

# React web app
web/node_modules/
web/dist/
web/dist-ssr/

# Python
__pycache__/
*.pyc
.env
.venv/
*.egg-info/
.pytest_cache/
test.db

# Signing keys and credentials
*.keystore
*.jks
keystore_base64.txt
# Exception: the debug keystore is committed so all CI runs (and local
# builds) produce APKs with a stable signature, which is required for
# in-app updates to pass the installed-signature check.
!app/debug.keystore

# macOS
.DS_Store

# Claude Code
.claude/

# Stray test/log artifacts
test.json
sync-*.json
parse-test.json
simple-test.json
build-log*.txt
compile-log.txt

# Nested bare git repo
averyTask.git/
