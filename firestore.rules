// Stubbed rules for local emulator use only.
// The production Firestore rules live in the Firebase console and were NOT
// imported into this repo during emulator setup (Phase B). These stubs allow
// any authenticated user full read/write access so the emulator is useful for
// sync testing — they are NOT a reflection of production rules and must not
// be deployed. See docs/FIREBASE_EMULATOR.md for context.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
