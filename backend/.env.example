DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/averytask
JWT_SECRET_KEY=  # REQUIRED: generate with `python -c "import secrets; print(secrets.token_urlsafe(64))"`
JWT_ALGORITHM=HS256
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Bearer token Grafana Cloud's hosted scraper presents on GET /metrics.
# Generate with `python -c "import secrets; print(secrets.token_urlsafe(32))"`,
# set the same value in Grafana Cloud's scrape job authorization.
METRICS_SCRAPE_TOKEN=
ENVIRONMENT=dev
