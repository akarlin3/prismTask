{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "alembic upgrade head && gunicorn app.main:app -c gunicorn.conf.py",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
