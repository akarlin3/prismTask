# PrismTask Web - Environment Variables
# Copy to .env and update values as needed

# Backend API base URL (defaults to production if not set)
VITE_API_BASE_URL=https://averytask-production.up.railway.app/api/v1

# Firebase Configuration
# These must be passed as Docker build args (--build-arg) so Vite inlines them at build time.
# Also add them to Railway's web service environment variables.
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
