2026-05-03T23:13:04.2215812Z 35-->/home/runner/work/prismTask/prismTask/app/src/main/AndroidManifest.xml:30:22-71
2026-05-03T23:13:04.2216895Z 36    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
