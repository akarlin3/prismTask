# coded in PrismTaskApplication.configureFirebaseEmulator),
# so no `adb reverse` is needed. Confirm by pinging the
# emulator UI from inside the AVD.
adb shell "ping -c 1 10.0.2.2 || true"
./gradlew connectedDebugAndroidTest --no-daemon --continue

